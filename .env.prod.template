# BITSM Production Environment — bitsm.io
# Copy to .env and fill in ALL values before first deploy.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"
# Generate FERNET_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ===== APP =====
APP_ENV=production
APP_NAME=BITSM
APP_URL=https://bitsm.io
LOG_LEVEL=WARNING

# ===== FLASK SESSION =====
SECRET_KEY=CHANGEME
SESSION_COOKIE_SECURE=true

# ===== ENCRYPTION =====
FERNET_KEY=CHANGEME

# ===== DATABASE =====
HELPDESK_PG_HOST=postgres
HELPDESK_PG_PORT=5432
HELPDESK_PG_DATABASE=helpdesk
HELPDESK_PG_USER=helpdesk_app
HELPDESK_PG_PASSWORD=CHANGEME
HELPDESK_PG_POOL_MIN=1
HELPDESK_PG_POOL_MAX=10

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0

# ===== AUTH: MICROSOFT 365 =====
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
AZURE_AUTHORITY=https://login.microsoftonline.com/common

# ===== AUTH: GOOGLE OAUTH =====
# Add https://bitsm.io/auth/callback/google to Google Cloud Console before cutover
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== AUTH: GENERAL =====
AUTH_ENABLED=true
SUPER_ADMIN_EMAILS=admin@your-domain.com
SUPER_ADMIN_DOMAINS=your-domain.com

# ===== ANTHROPIC =====
ANTHROPIC_API_KEY=

# ===== EMBEDDINGS =====
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# ===== EMAIL (RESEND) =====
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=hello@bitsm.io
DEFAULT_FROM_NAME=BITSM

# ===== INBOUND EMAIL =====
INBOUND_EMAIL_SECRET=CHANGEME
INBOUND_EMAIL_DOMAIN=bitsm.io

# ===== STRIPE =====
# IMPORTANT: Configure bitsm.io as the Stripe webhook endpoint
# BITSM endpoint active
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_BUSINESS=price_
STRIPE_PRICE_ENTERPRISE=price_

# ===== PHONE (PLATFORM POOL) =====
PLATFORM_ELEVENLABS_API_KEY=
PLATFORM_TWILIO_ACCOUNT_SID=
PLATFORM_TWILIO_AUTH_TOKEN=

# ===== PHONE (DEV/LEGACY) =====
DEV_TWILIO_ACCOUNT_SID=
DEV_TWILIO_AUTH_TOKEN=
DEV_TWILIO_PHONE_NUMBER=
DEV_ELEVENLABS_API_KEY=
DEV_ONCALL_NUMBER=

# ===== QUEUE =====
QUEUE_MAX_LLM_CONCURRENCY=5
QUEUE_POLL_INTERVAL=2.0

# ===== MONITORING =====
SENTRY_DSN=
