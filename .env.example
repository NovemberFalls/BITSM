# ============================================================
# BITSM Environment Configuration
# Copy this file to .env and fill in your values
#
# Tiers:
#   REQUIRED    — app will not start or function without these
#   RECOMMENDED — enables voice AI + messaging features
#   OPTIONAL    — billing, fallback AI, email, monitoring
# ============================================================


# --- REQUIRED (app won't function without these) ---

# Flask session signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Fernet encryption key for connector configs + backup encryption.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Rotating this key after data has been encrypted requires a data-migration
# script that decrypts each affected row with the old key and re-encrypts with the
# new key. Do not rotate FERNET_KEY in-place after any tenant has stored a BYOK
# credential or any backup blob has been written under the old key.
FERNET_KEY=your-fernet-key-here

# PostgreSQL 16 + pgvector
HELPDESK_PG_HOST=localhost
HELPDESK_PG_PORT=5433
HELPDESK_PG_DATABASE=helpdesk
HELPDESK_PG_USER=helpdesk_app
HELPDESK_PG_PASSWORD=your-db-password
HELPDESK_PG_POOL_MIN=0
HELPDESK_PG_POOL_MAX=10

# Redis (Flask session store)
REDIS_URL=redis://localhost:6379/0

# Anthropic — Atlas AI engine (L1 Haiku triage, L2 Sonnet escalation, pipeline tagging)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Voyage AI — text-to-vector embeddings for RAG search (primary embedding provider)
VOYAGE_API_KEY=your-voyage-key-here


# --- OAUTH (at least one provider required for login) ---

# Microsoft 365 OAuth (MSAL) — register an app at https://portal.azure.com → App registrations
# NOTE: These are your BITSM app registration credentials, not Azure infra credentials.
AZURE_CLIENT_ID=your-ms365-client-id
AZURE_CLIENT_SECRET=your-ms365-client-secret
AZURE_TENANT_ID=your-ms365-tenant-id
# Defaults to https://login.microsoftonline.com/{AZURE_TENANT_ID}; set to "common" for multi-tenant
AZURE_AUTHORITY=https://login.microsoftonline.com/common

# Google OAuth — register at https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret


# --- AUTH & ACCESS CONTROL ---

# Set to false to disable OAuth entirely in local dev (auto-provisions a dev super_admin user)
AUTH_ENABLED=true

# Optional: restrict OAuth sign-in to a single email domain (e.g. your-company.com)
ALLOWED_DOMAIN=

# Comma-separated emails that get super_admin on first login
SUPER_ADMIN_EMAILS=admin@your-company.com

# Comma-separated domains — any user from these domains gets super_admin on first login
SUPER_ADMIN_DOMAINS=your-company.com

# Idle session timeout in minutes (15-480); tenant setting overrides this per-tenant
IDLE_TIMEOUT_MINUTES=60

# Set to true in production to enforce Secure flag on session cookies
SESSION_COOKIE_SECURE=true

# --- FEATURE GATES ---

# Enable BYOK demo mode: new tenants auto-created as plan_tier='demo' with data purge
DEMO_MODE=false

# Days before demo tenant data is purged (default 7)
DEMO_TENANT_TTL_DAYS=7

# Set to false to disable new tenant auto-creation via OAuth login
TENANT_CREATION_ENABLED=true

# Global API rate limit (flask-limiter format)
RATE_LIMIT_DEFAULT=120 per minute


# --- RECOMMENDED (voice AI + messaging features) ---

# Platform ElevenLabs account — used for AI voice agents (phone helpdesk)
PLATFORM_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Platform Twilio account — used for voice calls + SMS/WhatsApp messaging
PLATFORM_TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
PLATFORM_TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# Dev/legacy Twilio pool — used for local testing only; not needed in production
DEV_TWILIO_ACCOUNT_SID=your-dev-twilio-sid-here
DEV_TWILIO_AUTH_TOKEN=your-dev-twilio-token-here
DEV_TWILIO_PHONE_NUMBER=+14155552671
DEV_ELEVENLABS_API_KEY=your-dev-elevenlabs-key-here
DEV_ONCALL_NUMBER=+14155559999


# --- OPTIONAL (billing, fallback AI, email, monitoring) ---

# Stripe billing — required only if you're monetizing with Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Stripe Price IDs for each plan tier
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BUSINESS=price_your-business-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-price-id

# OpenAI — used as fallback embedding provider if Voyage AI is unavailable
OPENAI_API_KEY=your-openai-key-here

# Embedding configuration (defaults are correct for Voyage AI primary)
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# AI model configuration (Claude model IDs — update when new versions release)
AI_MODEL_CHAT=claude-haiku-4-5-20251001
AI_MODEL_CHAT_L2=claude-sonnet-4-20250514
AI_MODEL_ROUTER=claude-haiku-4-5-20251001
AI_FALLBACK_PROVIDER=openai

# Resend — transactional email (ticket notifications, invite emails)
RESEND_API_KEY=re_your-resend-key-here
DEFAULT_FROM_EMAIL=helpdesk@bitsm.io
DEFAULT_FROM_NAME=BITSM

# Inbound email via Cloudflare Email Worker to BITSM webhook (HMAC auth)
INBOUND_EMAIL_SECRET=your-inbound-email-hmac-secret
INBOUND_EMAIL_DOMAIN=bitsm.io

# Azure Blob Storage — used by azure_backup.py for encrypted DB backups
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# Sentry error tracking (optional — omit or leave blank to disable)
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# SSH key for ops monitoring (optional — plan: replace with MI+Bastion)
BITSM_SSH_KEY=your-ssh-private-key-here


# --- APP & INFRASTRUCTURE ---

# Application environment tag (used by Sentry and logging)
APP_ENV=production

# Application name (shown in UI and email sender)
APP_NAME=BITSM

# Public-facing URL of your BITSM deployment
APP_URL=https://bitsm.io

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# Global API rate limit (SOC 2 CC6.8) — format: "N per period" e.g. "120 per minute"
RATE_LIMIT_DEFAULT=120 per minute

# Pipeline queue — max concurrent LLM calls across the auto_tag/enrich/engage/route lanes
QUEUE_MAX_LLM_CONCURRENCY=5

# Pipeline queue poll interval in seconds
QUEUE_POLL_INTERVAL=2.0
